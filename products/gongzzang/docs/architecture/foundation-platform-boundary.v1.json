  "allowed_integration_contracts": [
    {
      "kind": "http_api",
      "direction": "gongzzang_to_foundation_platform",
      "purpose": "catalog published API consumption"
    },
    {
      "kind": "runtime_vector_tile_manifest",
      "direction": "gongzzang_to_foundation_platform",
      "purpose": "public and reference map layer discovery"
    },
    {
      "kind": "outbox_webhook_event",
      "direction": "foundation_platform_to_gongzzang",
      "purpose": "consumer cache invalidation and read-model refresh"
    },
    {
      "kind": "immutable_anchor_artifact",
      "direction": "gongzzang_to_foundation_platform",
      "purpose": "PNU anchor read-model import"
    },
    {
      "kind": "lakehouse_registry_registration",
      "direction": "gongzzang_to_foundation_platform",
      "purpose": "Gongzzang-owned governed lakehouse artifact registration after verified writes"
    }
  ],
  "forbidden_integration_contracts": [
    {
      "kind": "direct_foundation_platform_database",
      "reason": "Foundation Platform database is not a Gongzzang runtime contract; Gongzzang must use published HTTP, event, or immutable artifact contracts only"
    },
    {
      "kind": "foundation_platform_listing_semantics",
      "reason": "Listing price, status, exposure, filter, and detail semantics remain Gongzzang-owned"
    },
    {
      "kind": "gongzzang_canonical_catalog_write",
      "reason": "Catalog canonical writes move to Foundation Platform through ADR 0034"
    },
    {
      "kind": "listing_owned_marker_coordinates",
      "reason": "Marker position must come from Foundation Platform PNU anchors"
    }
  ],
  "forbidden_canonical_catalog_tables": [
    {
      "table": "industrial_complex",
