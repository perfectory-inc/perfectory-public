# Copy this file to `.env.local` and fill real local-only secrets.
# `.env.local` is ignored by git. Do not commit real keys.

FOUNDATION_ADMIN_PASSWORD=REPLACE_WITH_RANDOM_URL_SAFE_ADMIN_PASSWORD
FOUNDATION_MIGRATOR_PASSWORD=REPLACE_WITH_RANDOM_URL_SAFE_MIGRATOR_PASSWORD
FOUNDATION_API_PASSWORD=REPLACE_WITH_RANDOM_URL_SAFE_API_PASSWORD
FOUNDATION_DB_PORT=15434
FOUNDATION_API_PORT=18080
FOUNDATION_REDIS_PORT=16379
FOUNDATION_PROMETHEUS_PORT=19090
FOUNDATION_ALERTMANAGER_PORT=19093
DATABASE_URL=postgres://foundation_api:REPLACE_WITH_FOUNDATION_API_PASSWORD@localhost:15434/foundation

# Identity Platform policy decisions. Identity's local compose publishes port 8080.
IDENTITY_API_BASE_URL=http://localhost:8080
ZITADEL_ISSUER_URL=http://localhost:18443
FOUNDATION_PLATFORM_ZITADEL_AUDIENCE=foundation-api
FOUNDATION_PLATFORM_IDENTITY_AUTHORIZATION_TIMEOUT_MS=2000

# Read-only data.go.kr building-register smoke.
DATA_GO_KR_SERVICE_KEY=
FOUNDATION_PLATFORM_BUILDING_REGISTER_SIGUNGU_CD=
FOUNDATION_PLATFORM_BUILDING_REGISTER_BJDONG_CD=

# Read-only VWorld cadastral smoke.
VWORLD_API_KEY=
VWORLD_DOMAIN=
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_PNU=
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_ATTR_FILTER=
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_GEOM_FILTER=

# Read-only R2 inventory smoke.
R2_ACCOUNT_ID=
R2_ENDPOINT=
# Foundation Platform-owned governed lakehouse bucket. Do not use the legacy `gongzzang` bucket for new writes.
# set explicitly; do NOT default to prod
R2_BUCKET_NAME=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
FOUNDATION_PLATFORM_BRONZE_OBJECT_STORAGE_DRIVER=r2
FOUNDATION_PLATFORM_R2_INVENTORY_PREFIX=
FOUNDATION_PLATFORM_R2_INVENTORY_MAX_KEYS=20

# Read-only R2 Data Catalog / Iceberg REST snapshot smoke.
FOUNDATION_PLATFORM_LAKEHOUSE_CATALOG_PROVIDER=r2_data_catalog
FOUNDATION_PLATFORM_LAKEHOUSE_CATALOG_URI=
FOUNDATION_PLATFORM_LAKEHOUSE_WAREHOUSE=foundation-platform
FOUNDATION_PLATFORM_LAKEHOUSE_CATALOG_TOKEN=
FOUNDATION_PLATFORM_LAKEHOUSE_SMOKE_TABLE=silver.industrial_complexes
FOUNDATION_PLATFORM_TRINO_BIND_ADDR=127.0.0.1
FOUNDATION_PLATFORM_TRINO_PORT=18081
FOUNDATION_PLATFORM_LAKEHOUSE_UID=185
FOUNDATION_PLATFORM_LAKEHOUSE_GID=185

# Optional remote Linux lakehouse compute runner.
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_SSH_TARGET=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_ROOT=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_ENV_FILE=.env.lakehouse
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_SSH_PATH=ssh
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_JOB=building_register_floors_smoke
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_EXECUTE=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_RECORD_AUDIT=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_RECORDED_BY_STAFF_ID=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_REQUEST_ID=
# Keep real provider object names and snapshot dates in this ignored local file or private ops.
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_BUILDING_REGISTER_SNAPSHOT_DATE=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_BUILDING_REGISTER_UNIT_SOURCE_OBJECT=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_BUILDING_REGISTER_TITLE_SOURCE_OBJECT=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_BUILDING_REGISTER_UNIT_AREA_SOURCE_OBJECT=

# Required validity metadata for snapshot-to-Silver publication commands.
FOUNDATION_PLATFORM_BUILDING_REGISTER_FLOOR_SILVER_HANDOFF_VALID_FROM_UTC=
FOUNDATION_PLATFORM_BUILDING_REGISTER_UNIT_SILVER_HANDOFF_VALID_FROM_UTC=
FOUNDATION_PLATFORM_BUILDING_REGISTER_UNIT_AREA_SILVER_HANDOFF_VALID_FROM_UTC=
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_SILVER_HANDOFF_VALID_FROM_UTC=
FOUNDATION_PLATFORM_OFFICIAL_ADMINISTRATIVE_BOUNDARY_SOURCE_VALID_FROM_UTC=

# Optional industrial-complex Catalog seed import.
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_CATALOG_SEED_PATH=

# Optional local override for pipeline graph control-plane artifacts.
FOUNDATION_PLATFORM_PIPELINE_GRAPH_REGISTRY_PATH=docs/catalog/pipeline-graph.v1.json

# Optional local outbox webhook receiver smoke. Keep real endpoint URLs in `.env.local` only.
FOUNDATION_PLATFORM_OUTBOX_WEBHOOK_ENDPOINTS=

# Optional write/read/delete R2 smoke. Only used with `-IncludeR2WriteSmoke`.
FOUNDATION_PLATFORM_R2_SMOKE_OBJECT_KEY=gold/_smoke/foundation-platform-r2-smoke.json

# Optional RAON Linux package inputs for building provider-acquisition batch images.
# Values are provider-discovered build inputs, not runtime secrets; keep real URLs/checksums local.
RAON_DEB_URL=
RAON_DEB_SHA256=

# PostgreSQL disaster recovery. Keep these credentials scoped to the recovery bucket.
FOUNDATION_RECOVERY_R2_BUCKET=
FOUNDATION_RECOVERY_R2_ENDPOINT_HOST=REPLACE_WITH_ACCOUNT_ID.r2.cloudflarestorage.com
FOUNDATION_RECOVERY_R2_ACCESS_KEY_ID=
FOUNDATION_RECOVERY_R2_SECRET_ACCESS_KEY=
FOUNDATION_RECOVERY_REPOSITORY_PATH=/postgres/foundation
FOUNDATION_RECOVERY_REPOSITORY_CIPHER_PASS=
# Local default; deployed systemd uses /var/lib/foundation-platform/recovery.
FOUNDATION_RECOVERY_EVIDENCE_DIR=target/recovery
