# Root ignores (belt-and-suspenders over each area's own .gitignore).
# Rust build output — anywhere in the monorepo, including tools/xtask.
target/

# Node / frontend
node_modules/
.pnpm-store/

# Python bytecode
__pycache__/
*.py[cod]

# Local env & secrets (never commit; secret-scan + these two lines are the guard)
.env
.env.local
.env.*.local

# OS / editor cruft
.DS_Store
Thumbs.db
