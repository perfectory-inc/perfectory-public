{
  "title": "Foundation Platform API",
  "schemaVersion": 39,
  "tags": ["foundation-platform", "api", "sss"],
  "timezone": "browser",
  "panels": [
    {
      "type": "stat",
      "title": "API up",
      "targets": [
        {
          "expr": "foundation_api_up",
          "legendFormat": "api"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Database ready",
      "targets": [
        {
          "expr": "foundation_api_database_ready",
          "legendFormat": "database"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 }
    },
    {
      "type": "timeseries",
      "title": "Lakehouse last success created",
      "targets": [
        {
          "expr": "foundation_platform_lakehouse_batch_last_success_created_at_seconds",
          "legendFormat": "{{contract}}"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Lakehouse last success recorded",
      "targets": [
        {
          "expr": "foundation_platform_lakehouse_batch_last_success_recorded_at_seconds",
          "legendFormat": "{{contract}}"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Lakehouse last success rows",
      "targets": [
        {
          "expr": "foundation_platform_lakehouse_batch_last_success_row_count",
          "legendFormat": "{{contract}}"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 }
    },
    {
      "type": "timeseries",
      "title": "Ingestion last finished",
      "targets": [
        {
          "expr": "foundation_platform_ingestion_run_last_finished_at_seconds",
          "legendFormat": "{{source}} {{status}}"
        }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 }
    },
    {
      "type": "timeseries",
      "title": "Ingestion duration",
      "targets": [
        {
          "expr": "foundation_platform_ingestion_run_last_duration_seconds",
          "legendFormat": "{{source}} {{status}}"
