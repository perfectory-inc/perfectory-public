FROM rust:1.96.0-bookworm@sha256:5e2214abe154fe26e39f64488952e5c991eeed1d6d6da7cc8381ae83927f0cfc AS rust-builder

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

WORKDIR /src

# Toolchain pin is the base image tag (rust:1.96.0, guard-enforced); root
# rust-toolchain.toml is outside this context, cargo uses image default 1.96.0.
COPY Cargo.toml Cargo.lock /src/
COPY crates /src/crates
COPY services /src/services

RUN cargo build --locked --release -p foundation-outbox-publisher

FROM python:3.11-bookworm@sha256:b7ae8a4dcc0ab327e333c5e46a3eaa6c1b0ff585bed77e01cd6de4be1325837e

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ARG RAON_DEB_URL
ARG RAON_DEB_SHA256
ARG DEBIAN_SNAPSHOT=20260713T000000Z
ARG PATCHRIGHT_CHROMIUM_REVISION=1228
ARG PATCHRIGHT_CHROMIUM_VERSION=149.0.7827.55
ARG PATCHRIGHT_BROWSER_BUNDLE_SHA256=65012a433ce5efb77d26fdc13c861ebaf19cef45d33aeda03e214ef156d79eba

ENV PYTHONUNBUFFERED=1 \
    PLAYWRIGHT_BROWSERS_PATH=/ms-playwright \
    FOUNDATION_PLATFORM_PROVIDER_ACQUISITION_STAGING_DIR=/work/staging

RUN test -n "${RAON_DEB_URL}" \
    && test -n "${RAON_DEB_SHA256}"

RUN rm -f /etc/apt/sources.list.d/debian.sources \
    && printf 'deb [check-valid-until=no] http://snapshot.debian.org/archive/debian/%s/ bookworm main\n' "${DEBIAN_SNAPSHOT}" > /etc/apt/sources.list \
    && printf 'deb [check-valid-until=no] http://snapshot.debian.org/archive/debian/%s/ bookworm-updates main\n' "${DEBIAN_SNAPSHOT}" >> /etc/apt/sources.list \
    && printf 'deb [check-valid-until=no] http://snapshot.debian.org/archive/debian-security/%s/ bookworm-security main\n' "${DEBIAN_SNAPSHOT}" >> /etc/apt/sources.list

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates=20230311+deb12u1 \
        curl=7.88.1-10+deb12u15 \
        cron=3.0pl1-162 \
        dbus-x11=1.14.10-1~deb12u1 \
        procps=2:4.0.2-3 \
        xvfb=2:21.1.7-3+deb12u12 \
        libasound2=1.2.8-1+b1 \
        libatk-bridge2.0-0=2.46.0-5 \
        libatk1.0-0=2.46.0-5 \
        libcairo2=1.16.0-7 \
        libcups2=2.4.2-3+deb12u9 \
        libdbus-1-3=1.14.10-1~deb12u1 \
        libdrm2=2.4.114-1+b1 \
        libgbm1=22.3.6-1+deb12u2 \
        libgtk-3-0=3.24.38-2~deb12u3 \
        libnspr4=2:4.35-1 \
        libnss3=2:3.87.1-1+deb12u2 \
        libpango-1.0-0=1.50.12+ds-1 \
        libx11-xcb1=2:1.8.4-2+deb12u2 \
        libxcomposite1=1:0.4.5-1 \
        libxdamage1=1:1.1.6-1 \
        libxfixes3=1:6.0.0-2 \
        libxkbcommon0=1.5.0-1 \
        libxrandr2=2:1.5.2-2+b1 \
        libxss1=1:1.2.3-1 \
        fonts-liberation=1:1.07.4-11 \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL "${RAON_DEB_URL}" -o /tmp/raonk-2018_amd64.deb \
    && echo "${RAON_DEB_SHA256}  /tmp/raonk-2018_amd64.deb" | sha256sum -c - \
    && apt-get update \
    && apt-get install -y --no-install-recommends /tmp/raonk-2018_amd64.deb \
    && rm -f /tmp/raonk-2018_amd64.deb \
    && rm -rf /var/lib/apt/lists/* \
    && (crontab -l 2>/dev/null | grep -v '/opt/raonk-2018/scripts/service.sh' | crontab - || true)

WORKDIR /app

COPY --from=rust-builder /src/target/release/foundation-outbox-publisher /usr/local/bin/foundation-outbox-publisher
COPY services/foundation-provider-acquisition-worker/pyproject.toml /app/services/foundation-provider-acquisition-worker/pyproject.toml
COPY services/foundation-provider-acquisition-worker/requirements.lock /app/services/foundation-provider-acquisition-worker/requirements.lock
COPY services/foundation-provider-acquisition-worker/src /app/services/foundation-provider-acquisition-worker/src
COPY services/foundation-provider-acquisition-worker/scripts /app/services/foundation-provider-acquisition-worker/scripts

RUN python -m pip install --no-cache-dir --require-hashes \
        -r /app/services/foundation-provider-acquisition-worker/requirements.lock \
    && python -m pip install --no-cache-dir --no-deps /app/services/foundation-provider-acquisition-worker \
    && python -c 'import json, pathlib, patchright, sys; data=json.loads(next(pathlib.Path(patchright.__file__).parent.rglob("browsers.json")).read_text()); chromium=next(item for item in data["browsers"] if item["name"] == "chromium"); sys.exit(0 if chromium["revision"] == "'"${PATCHRIGHT_CHROMIUM_REVISION}"'" and chromium["browserVersion"] == "'"${PATCHRIGHT_CHROMIUM_VERSION}"'" else 1)' \
    && python -m patchright install chromium \
    && test "$(find /ms-playwright -type f -print0 | sort -z | xargs -0 sha256sum | sha256sum | cut -d' ' -f1)" = "${PATCHRIGHT_BROWSER_BUNDLE_SHA256}" \
    && chmod +x /app/services/foundation-provider-acquisition-worker/scripts/raon-batch-entrypoint.sh

RUN useradd --create-home --shell /bin/bash app \
    && mkdir -p /work/staging \
    && chown -R app:app /work /app /ms-playwright /usr/local/bin/foundation-outbox-publisher

USER app

ENTRYPOINT ["/app/services/foundation-provider-acquisition-worker/scripts/raon-batch-entrypoint.sh"]
