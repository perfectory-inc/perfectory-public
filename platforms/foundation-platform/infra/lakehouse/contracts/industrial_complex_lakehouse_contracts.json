        { "name": "official_area_sqm", "logical_type": "decimal(18,2)", "required": false },
        { "name": "source_record_id", "logical_type": "string", "required": true },
        { "name": "source_snapshot_id", "logical_type": "string", "required": true },
        { "name": "valid_from_utc", "logical_type": "timestamp", "required": true },
        { "name": "valid_to_utc", "logical_type": "timestamp", "required": false },
        { "name": "ingested_at_utc", "logical_type": "timestamp", "required": true },
        { "name": "row_checksum_sha256", "logical_type": "string", "required": true }
      ],
      "partition_spec": ["sido_code", "bucket(32, complex_id)"],
      "sort_order": ["sigungu_code", "complex_name_normalized", "official_complex_code"],
      "quality_gates": [
        "(official_complex_code, source_snapshot_id) unique",
