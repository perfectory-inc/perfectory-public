# === Gongzzang API ===
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
API_LISTEN_ADDR=0.0.0.0:8080

# === Foundation Platform HTTP contracts ===
# Foundation Platform owns Catalog facts, parcel/building lookups, marker anchors, and
# public reference spatial layers. Gongzzang consumes those through HTTP contracts only.
FOUNDATION_PLATFORM_API_BASE_URL=http://127.0.0.1:18082
FOUNDATION_PLATFORM_WORKLOAD_IDENTITY_TOKEN_FILE=
FOUNDATION_PLATFORM_WEBHOOK_SECRET=dev-foundation-platform-webhook-secret-must-be-shared
NEXT_PUBLIC_FOUNDATION_PLATFORM_BASE_URL=http://127.0.0.1:18082

NEXT_PUBLIC_TILES_MANIFEST_URL=

# === Naver Maps ===
NEXT_PUBLIC_NAVER_MAPS_CLIENT_ID=replace_with_naver_maps_client_id

# === Auth ===
ZITADEL_ISSUER=http://localhost:8443
ZITADEL_CLIENT_ID=replace_with_zitadel_client_id
ZITADEL_AUDIENCE=replace_with_zitadel_audience
ZITADEL_REDIRECT_URI=http://localhost:3000/api/auth/callback
SESSION_SECRET=change-me-to-random-32-byte-base64-string-aaaaaaaaaa
INTERNAL_AUTH_SECRET=dev-internal-auth-must-be-shared

# === Gongzzang database and cache ===
# Local Postgres uses infrastructure/docker/docker-compose.yml.
# The default host port is 15432 because 5500 can be reserved by Windows.
DATABASE_URL=postgres://gongzzang:changeme_local_only@localhost:15432/gongzzang
REDIS_URL=redis://localhost:6379

# === Listing photo storage ===
# Gongzzang owns listing photo upload storage. It uses the Gongzzang-owned
# lakehouse bucket and writes under the media/listing-photo object namespace.
LISTING_PHOTO_R2_ACCOUNT_ID=
LISTING_PHOTO_R2_ACCESS_KEY=
LISTING_PHOTO_R2_SECRET_KEY=
LISTING_PHOTO_R2_BUCKET=gongzzang-lakehouse-prod

# === Gongzzang lakehouse object storage ===
# Storage for Gongzzang-owned Bronze/Silver/Gold datasets and media object
# namespaces. This is separate from Foundation Platform Catalog storage.
GONGZZANG_LAKEHOUSE_R2_ACCOUNT_ID=
GONGZZANG_LAKEHOUSE_R2_ACCESS_KEY=
GONGZZANG_LAKEHOUSE_R2_SECRET_KEY=
GONGZZANG_LAKEHOUSE_R2_BUCKET=gongzzang-lakehouse-prod

# === Observability ===
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=gongzzang-api

# === Runtime ===
APP_ENV=local
NODE_ENV=development
OUTBOX_LAKEHOUSE_REGISTRY_ENABLED=false
RUST_LOG=info
RUST_BACKTRACE=1
