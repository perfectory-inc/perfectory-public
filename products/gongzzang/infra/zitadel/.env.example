# Copy this file to .env and replace every blank secret before starting Compose.
# Blank values are intentionally rejected by docker-compose.yml.
ZITADEL_DB_PASSWORD=
ZITADEL_MASTERKEY=
ZITADEL_ADMIN_PASSWORD=

# Non-secret local development settings.
ZITADEL_ADMIN_USERNAME=admin
ZITADEL_ADMIN_EMAIL=admin@zitadel.localhost
ZITADEL_DB_HOST_PORT=15433
ZITADEL_HOST_PORT=18443
ZITADEL_REDIS_HOST_PORT=6379
