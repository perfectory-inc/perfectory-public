# Local model runtime profile.
# Open WebUI at <model-runtime-host>:8080 is intentionally not used here.
# The Rust platform talks to the model runtime through an OpenAI-compatible API.
# Replace <model-runtime-host> with your local model-runtime hostname/IP; do not
# commit the real address.

INTELLIGENCE_API_BIND=0.0.0.0:8010
# Fail-closed guard: non-loopback binds require inbound auth.
# Generate a strong random token and keep it in a secrets manager.
INTELLIGENCE_INBOUND_AUTH_MODE=shared-token
INTELLIGENCE_INBOUND_SERVICE_TOKEN=replace-with-a-strong-random-secret
MODEL_RUNTIME_BASE_URL=http://<model-runtime-host>:11434
MODEL_RUNTIME_CHAT_PATH=/v1/chat/completions
MODEL_RUNTIME_DEFAULT_MODEL=gemma2:9b
MODEL_RUNTIME_PROFILE_ID=normalization-ko

# Required for reasoning-first models such as Qwen 3.6 when the caller expects
# the final answer in OpenAI-compatible message.content rather than reasoning.
# Allowed values: none, low, medium, high.
# MODEL_RUNTIME_REASONING_EFFORT=none
