{
  "schema_version": "gongzzang.platform_integration.service_auth_policy.v1",
  "platform_naming": {
    "decision_source": "docs/adr/0048-horizontal-platform-redefinition.md",
    "canonical_platform_slug": "foundation-platform",
    "policy_final_owner_slug": "identity-platform"
  },
  "repo_slug": "gongzzang",
  "owner": "gongzzang",
  "status": "active",
  "outbound_identities": [
    {
      "id": "gongzzang_api_to_foundation_api",
      "source_service": "gongzzang-api",
      "target_service": "foundation-api",
