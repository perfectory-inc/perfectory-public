# foundation-platform 로컬 개발 환경변수.
# 실제 사용 시 `.env.local` 로 복사한 뒤 값 조정.

FOUNDATION_ADMIN_PASSWORD=REPLACE_WITH_RANDOM_URL_SAFE_ADMIN_PASSWORD
FOUNDATION_MIGRATOR_PASSWORD=REPLACE_WITH_RANDOM_URL_SAFE_MIGRATOR_PASSWORD
FOUNDATION_API_PASSWORD=REPLACE_WITH_RANDOM_URL_SAFE_API_PASSWORD
FOUNDATION_DB_PORT=15434
FOUNDATION_API_PORT=18080
FOUNDATION_REDIS_PORT=16379
FOUNDATION_PROMETHEUS_PORT=19090
FOUNDATION_ALERTMANAGER_PORT=19093

# PostgreSQL runtime connection after the Compose migration chain finishes.
DATABASE_URL=postgres://foundation_api:REPLACE_WITH_FOUNDATION_API_PASSWORD@localhost:15434/foundation

FOUNDATION_PLATFORM_DB_MAX_CONNECTIONS=8
FOUNDATION_PLATFORM_DB_MIN_CONNECTIONS=1
FOUNDATION_PLATFORM_DB_ACQUIRE_TIMEOUT_MS=500
FOUNDATION_PLATFORM_DB_STATEMENT_TIMEOUT_MS=2500
FOUNDATION_PLATFORM_DB_IDLE_TIMEOUT_SECONDS=300

# HTTP bind address. 8080 충돌 시 예: 127.0.0.1:18080
FOUNDATION_PLATFORM_API_BIND_ADDR=0.0.0.0:8080
FOUNDATION_PLATFORM_HTTP_REQUEST_TIMEOUT_MS=3000
FOUNDATION_PLATFORM_HTTP_MAX_CONCURRENCY=128
FOUNDATION_PLATFORM_HTTP_BODY_LIMIT_BYTES=1048576

# Pipeline graph control-plane artifacts served by /catalog/v1/pipeline-graph.
# Defaults point at repository canonical artifacts, not .example fixtures.
FOUNDATION_PLATFORM_PIPELINE_GRAPH_REGISTRY_PATH=docs/catalog/pipeline-graph.v1.json

# Zitadel — gongzzang/infra/zitadel/docker-compose.yml 의 인스턴스를 공유.
# staff organization 의 issuer URL.
ZITADEL_ISSUER_URL=http://localhost:18443
# foundation-platform API 전용 audience (aud claim). 다른 클라이언트용 토큰 혼동을 차단해요.
FOUNDATION_PLATFORM_ZITADEL_AUDIENCE=foundation-api
FOUNDATION_PLATFORM_IDENTITY_AUTHORIZATION_TIMEOUT_MS=2000
# Identity Platform policy decisions. Identity's local compose publishes port 8080.
IDENTITY_API_BASE_URL=http://localhost:8080

# Redis (JTI denylist + 캐시)
REDIS_URL=redis://localhost:16379

# Browser consumers allowed to call foundation-platform directly.
# Gongzzang local dev server fetches `/catalog/v1/vector-tiles/manifest`.
FOUNDATION_PLATFORM_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Outbox publisher object storage driver.
# `log` keeps local development self-contained.
# `r2` publishes Catalog-owned objects such as `gold/manifest.json` to Cloudflare R2.
FOUNDATION_PLATFORM_OBJECT_STORAGE_DRIVER=log

# Optional outbox webhook fan-out for consumer cache invalidation.
# Format: name=https://consumer.internal/foundation-platform/events;name=https://other.internal/foundation-platform/events
# Plain http is accepted only for localhost / 127.0.0.1 development endpoints.
FOUNDATION_PLATFORM_OUTBOX_WEBHOOK_ENDPOINTS=

# Cloudflare R2. Required when FOUNDATION_PLATFORM_OBJECT_STORAGE_DRIVER=r2.
R2_ACCOUNT_ID=
# Foundation Platform-owned governed lakehouse bucket. Do not use the legacy `gongzzang` bucket for new writes.
# set explicitly; do NOT default to prod
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

# Bronze collection writes use the same Foundation Platform-owned R2 lakehouse bucket by default.
FOUNDATION_PLATFORM_BRONZE_OBJECT_STORAGE_DRIVER=r2

# Optional R2 smoke target. The default is a dedicated non-runtime object key.
# Do not set this to gold/manifest.json.
FOUNDATION_PLATFORM_R2_SMOKE_OBJECT_KEY=gold/_smoke/foundation-platform-r2-smoke.json

# Optional read-only R2 inventory check.
# Prefix may be empty for the bucket root, or a provider-relative prefix such as bronze/ or gold/.
FOUNDATION_PLATFORM_R2_INVENTORY_PREFIX=
FOUNDATION_PLATFORM_R2_INVENTORY_MAX_KEYS=100
FOUNDATION_PLATFORM_R2_INVENTORY_LIVE_SMOKE=

# Lakehouse catalog. Required for R2 Data Catalog / Iceberg REST smoke and adapters.
FOUNDATION_PLATFORM_LAKEHOUSE_CATALOG_PROVIDER=r2_data_catalog
FOUNDATION_PLATFORM_LAKEHOUSE_CATALOG_URI=
FOUNDATION_PLATFORM_LAKEHOUSE_WAREHOUSE=foundation-platform
FOUNDATION_PLATFORM_LAKEHOUSE_CATALOG_TOKEN=
FOUNDATION_PLATFORM_LAKEHOUSE_OAUTH2_SERVER_URI=

# Optional read-only live lakehouse smoke. Must be exactly "1" to touch the live catalog.
FOUNDATION_PLATFORM_LAKEHOUSE_LIVE_SMOKE=
FOUNDATION_PLATFORM_LAKEHOUSE_SMOKE_TABLE=silver.industrial_complexes

# Optional Spark Iceberg write smoke. Defaults target a dedicated smoke table.
FOUNDATION_PLATFORM_SPARK_ICEBERG_CATALOG_NAME=r2
FOUNDATION_PLATFORM_SPARK_ICEBERG_NAMESPACE=silver
FOUNDATION_PLATFORM_SPARK_ICEBERG_TABLE=industrial_complexes_smoke
FOUNDATION_PLATFORM_SPARK_ICEBERG_PACKAGES=org.apache.iceberg:iceberg-spark-runtime-3.5_2.12:1.6.1,org.apache.iceberg:iceberg-aws-bundle:1.6.1
FOUNDATION_PLATFORM_SPARK_GOLD_SOURCE_NAMESPACE=silver
FOUNDATION_PLATFORM_SPARK_GOLD_SOURCE_TABLE=industrial_complexes_smoke
FOUNDATION_PLATFORM_SPARK_GOLD_TARGET_NAMESPACE=gold
FOUNDATION_PLATFORM_SPARK_GOLD_TARGET_TABLE=complex_catalog_smoke

# Industrial-complex Gold pointer publish. Run after Spark/Iceberg writes the Gold artifact.
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_COMPLEX_ID=
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_CURRENT_VERSION=
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_EXPECTED_CURRENT_VERSION=
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_PROFILE_OBJECT_KEY=
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_SPATIAL_LOCATOR_OBJECT_KEY=
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_SOURCE=foundation-platform.spark.industrial_complex_gold
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_SOURCE_URL=
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_SOURCE_EXTERNAL_ID=
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_SOURCE_SNAPSHOT_ID=
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_ICEBERG_SNAPSHOT_ID=
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_PROFILE_ROW_COUNT=
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_PROFILE_SIZE_BYTES=
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_SPATIAL_LOCATOR_SIZE_BYTES=
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_PROFILE_CHECKSUM_SHA256=
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_GOLD_POINTER_PUBLISHED_AT_UTC=

# Korean public data portal common decoded service key. Keep the real key in .env.local only.
DATA_GO_KR_SERVICE_KEY=
FOUNDATION_PLATFORM_DATA_GO_KR_LIVE_SMOKE=
FOUNDATION_PLATFORM_DATA_GO_KR_MAX_ATTEMPTS=3
FOUNDATION_PLATFORM_DATA_GO_KR_REQUEST_TIMEOUT_SECONDS=30
FOUNDATION_PLATFORM_DATA_GO_KR_RETRY_INITIAL_BACKOFF_MS=250
FOUNDATION_PLATFORM_DATA_GO_KR_RETRY_MAX_BACKOFF_MS=5000

# VWorld OpenAPI key for VWorld NED/data/WFS/WMS adapters. Keep the real key in .env.local only.
VWORLD_API_KEY=
VWORLD_DOMAIN=
FOUNDATION_PLATFORM_VWORLD_NED_BASE_URI=https://api.vworld.kr/ned/data
FOUNDATION_PLATFORM_VWORLD_DATA_BASE_URI=https://api.vworld.kr
FOUNDATION_PLATFORM_VWORLD_USER_AGENT=foundation-outbox-publisher/0.1
FOUNDATION_PLATFORM_VWORLD_MAX_ATTEMPTS=3
FOUNDATION_PLATFORM_VWORLD_REQUEST_TIMEOUT_SECONDS=30
FOUNDATION_PLATFORM_VWORLD_RETRY_INITIAL_BACKOFF_MS=250
FOUNDATION_PLATFORM_VWORLD_RETRY_MAX_BACKOFF_MS=5000

# VWorld provider dataset-file downloads require a logged-in session.
# The ingestor prefers FOUNDATION_PLATFORM_VWORLD_DATASET_COOKIE_HEADER when supplied,
# otherwise it logs in once per run with these credentials and reuses the session cookie.
FOUNDATION_PLATFORM_VWORLD_DATASET_USERNAME=
FOUNDATION_PLATFORM_VWORLD_DATASET_PASSWORD=
FOUNDATION_PLATFORM_VWORLD_DATASET_COOKIE_HEADER=

# VWorld cadastral 2D Data API smoke / Bronze ingestion defaults.
# Live writes must be explicitly enabled.
# leave unset — source_slug() derives the canonical {provider}__{dataset} slug; an old/mismatched value now hard-fails
#FOUNDATION_PLATFORM_VWORLD_CADASTRAL_SOURCE_SLUG=
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_DATASET=LP_PA_CBND_BUBUN
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_PNU=
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_ATTR_FILTER=
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_GEOM_FILTER=
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_GRID_BBOX=
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_GRID_ROWS=1
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_GRID_COLUMNS=1
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_COLUMNS=pnu,jibun,bonbun,bubun,addr,ag_geom
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_PAGE=1
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_SIZE=10
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_MAX_PAGES=1
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_ADAPTIVE_SUBDIVISION=false
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_MAX_SUBDIVISION_DEPTH=4
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_CRS=EPSG:4326
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_GEOMETRY=true
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_ATTRIBUTE=true
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_LIVE_WRITE=

# VWorld land-register Bronze ingestion defaults. Live writes must be explicitly enabled.
# leave unset — source_slug() derives the canonical {provider}__{dataset} slug; an old/mismatched value now hard-fails
#FOUNDATION_PLATFORM_VWORLD_LAND_REGISTER_SOURCE_SLUG=
FOUNDATION_PLATFORM_VWORLD_LAND_REGISTER_OPERATION=ladfrlList
FOUNDATION_PLATFORM_VWORLD_LAND_REGISTER_PNU=
FOUNDATION_PLATFORM_VWORLD_LAND_REGISTER_PAGE_NO=1
FOUNDATION_PLATFORM_VWORLD_LAND_REGISTER_NUM_OF_ROWS=10
FOUNDATION_PLATFORM_VWORLD_LAND_REGISTER_MAX_PAGES=1
FOUNDATION_PLATFORM_VWORLD_LAND_REGISTER_LIVE_WRITE=

# Building-register Bronze ingestion defaults. Live writes must be explicitly enabled.
# leave unset — building-register slug is per-operation; source_slug() derives the canonical {provider}__{dataset} slug; an old/mismatched value now hard-fails
#FOUNDATION_PLATFORM_BUILDING_REGISTER_SOURCE_SLUG=
FOUNDATION_PLATFORM_BUILDING_REGISTER_BASE_URI=https://apis.data.go.kr/1613000/BldRgstHubService
FOUNDATION_PLATFORM_BUILDING_REGISTER_OPERATION=getBrTitleInfo
FOUNDATION_PLATFORM_BUILDING_REGISTER_SIGUNGU_CD=
FOUNDATION_PLATFORM_BUILDING_REGISTER_BJDONG_CD=
FOUNDATION_PLATFORM_BUILDING_REGISTER_PAGE_NO=1
FOUNDATION_PLATFORM_BUILDING_REGISTER_NUM_OF_ROWS=100
FOUNDATION_PLATFORM_BUILDING_REGISTER_MAX_PAGES=1
FOUNDATION_PLATFORM_BUILDING_REGISTER_LIVE_WRITE=
FOUNDATION_PLATFORM_BUILDING_REGISTER_RECONCILE_RUN_ID=

# Industrial-complex Catalog seed import. Use a real JSONL file, not the .example fixture.
FOUNDATION_PLATFORM_INDUSTRIAL_COMPLEX_CATALOG_SEED_PATH=

# Optional lakehouse query engine profile.
# docker compose -f compose.lakehouse.yml --profile lakehouse-query up -d trino
FOUNDATION_PLATFORM_TRINO_BIND_ADDR=127.0.0.1
FOUNDATION_PLATFORM_TRINO_PORT=18081
FOUNDATION_PLATFORM_LAKEHOUSE_UID=185
FOUNDATION_PLATFORM_LAKEHOUSE_GID=185

# Optional remote Linux lakehouse compute runner.
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_SSH_TARGET=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_ROOT=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_ENV_FILE=.env.lakehouse
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_SSH_PATH=ssh
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_JOB=building_register_floors_smoke
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_EXECUTE=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_RECORD_AUDIT=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_RECORDED_BY_STAFF_ID=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_REQUEST_ID=
# Private operations must bind an exact, mutually consistent provider snapshot.
# No live provider object name or current snapshot date is stored in public source.
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_BUILDING_REGISTER_SNAPSHOT_DATE=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_BUILDING_REGISTER_UNIT_SOURCE_OBJECT=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_BUILDING_REGISTER_TITLE_SOURCE_OBJECT=
FOUNDATION_PLATFORM_REMOTE_LAKEHOUSE_BUILDING_REGISTER_UNIT_AREA_SOURCE_OBJECT=

# Required validity metadata for snapshot-to-Silver publication commands.
FOUNDATION_PLATFORM_BUILDING_REGISTER_FLOOR_SILVER_HANDOFF_VALID_FROM_UTC=
FOUNDATION_PLATFORM_BUILDING_REGISTER_UNIT_SILVER_HANDOFF_VALID_FROM_UTC=
FOUNDATION_PLATFORM_BUILDING_REGISTER_UNIT_AREA_SILVER_HANDOFF_VALID_FROM_UTC=
FOUNDATION_PLATFORM_VWORLD_CADASTRAL_SILVER_HANDOFF_VALID_FROM_UTC=
FOUNDATION_PLATFORM_OFFICIAL_ADMINISTRATIVE_BOUNDARY_SOURCE_VALID_FROM_UTC=

# 로깅 (tracing-subscriber)
RUST_LOG=foundation_api=debug,catalog_application=debug,info

# PostgreSQL disaster recovery. Use a bucket and credential isolated from the lakehouse writer.
# The repository passphrase is client-side AES-256 encryption material and must stay outside Git.
FOUNDATION_RECOVERY_R2_BUCKET=foundation-platform-postgres-recovery-prod
FOUNDATION_RECOVERY_R2_ENDPOINT_HOST=REPLACE_WITH_ACCOUNT_ID.r2.cloudflarestorage.com
FOUNDATION_RECOVERY_R2_ACCESS_KEY_ID=
FOUNDATION_RECOVERY_R2_SECRET_ACCESS_KEY=
FOUNDATION_RECOVERY_REPOSITORY_PATH=/postgres/foundation
FOUNDATION_RECOVERY_REPOSITORY_CIPHER_PASS=
# Local default; deployed systemd uses /var/lib/foundation-platform/recovery.
FOUNDATION_RECOVERY_EVIDENCE_DIR=target/recovery
